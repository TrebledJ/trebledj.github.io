<!DOCTYPE html>
<html lang="{{ site.language | default("en") }}">
    {% include "head.html" %}
    <body>
        {% include "header.html" %}
        {% if not site.banner.sticky %}
            {% include "banner.html" %}
        {% endif %}
        {{ content | safe }}
        {% include "footer.html" %}

        <script defer src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
        <script defer src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.11.8/dist/umd/popper.min.js"></script>
        <script defer src="https://cdn.jsdelivr.net/npm/lunr@2.3.9/lunr.min.js"></script>

        {# Bundle JS. #}
        {% js %}
            var tocOptions = '{{ tocOptions | safe }}';
            var site = {
                typewrite: {{ site.typewrite | dump | safe }},
                search: {{ site.search | dump | safe }},
                lightbox: {{ site.lightbox | dump | safe }},
            };
        {% endjs %}
        {% js %} {% include "assets/js.bundle/head.js" %} {% endjs %}
        {% js %} {% include "assets/js.bundle/banner.js.njk" %} {% endjs %}
        {% js %} {% include "assets/js.bundle/lightbox.js.njk" %} {% endjs %}
        {% js %} {% include "assets/js.bundle/404.js" %} {% endjs %}
        {% js %} {% include "assets/js.bundle/post.js" %} {% endjs %}
        {% js %} {% include "assets/js.bundle/search.js" %} {% endjs %}
        {% js %} {% include "assets/js.bundle/typewriter.js" %} {% endjs %}
        {% js %} {% include "assets/js.bundle/my-typewrite.js" %} {% endjs %}
        {% set jsBundle %}
            {%- getBundleFileUrl "js" -%}
        {% endset %}
        <script defer src="{{jsBundle}}"></script>

        {# <script defer src="/js/head.js"></script>
        <script defer src="/js/search.js"></script>

        {% if assets %}
            {% if assets.js %}
                {% for asset in assets.js %}
                    <script defer src="{{asset}}"></script>
                {% endfor %}
            {% endif %}
        {% endif %} #}

        {% if use_math %}
            {# {% include "utilities/mathjax.html" %} #}
            {% include "utilities/katex.html" %}
        {% endif %}
        {% if site.analytics %}
            {% include "utilities/analytics.html" %}
        {% endif %}
    </body>
</html>